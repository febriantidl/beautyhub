APP_NAME=BeautyHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── DATABASE (MySQL / Laragon) ────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=beautyhub_db
DB_USERNAME=root
DB_PASSWORD=

# ── SESSION & CACHE ───────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── FILESYSTEM ───────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

VITE_APP_NAME="${APP_NAME}"
